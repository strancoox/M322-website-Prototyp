{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "rootDir": "./ts",
    "outDir": "./js",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "removeComments": false,
    "sourceMap": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["ts/**/*.ts"],
  "exclude": ["node_modules", "js"]
}
